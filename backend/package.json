{
  "name": "voice-karar-backend",
  "version": "1.0.0",
  "description": "Backend service for Voice Karar - AI-powered platform to convert informal verbal agreements to structured digital agreements.",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test:record": "keploy record -c 'npm run dev'",
    "test:run": "keploy test -c 'npm run dev' --delay 5",
    "test:record:no-proxy": "keploy record -c 'npm run dev' --noProxy",
    "test:unit": "echo \"Unit tests not configured\"",
    "test": "npm run test:run"
  },
  "keywords": [
    "voice-karar",
    "express",
    "mongodb",
    "ai-agreements",
    "hackathon"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.1"
  },
  "devDependencies": {
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.0"
  }
}
